# =====================================================
# AGENT FRAMEWORK - ENVIRONMENT VARIABLES
# =====================================================
# Copy this file to .env and fill in the values.
# IMPORTANT: Never commit .env to git!
#
# Required variables are marked with (REQUIRED)
# Optional variables have sensible defaults

# =====================================================
# SERVER CONFIGURATION
# =====================================================
SERVER_PORT=8080
APP_NAME=agent-framework

# =====================================================
# DATABASE CONFIGURATION (REQUIRED)
# =====================================================
DB_NAME=agent_framework
DB_USER=agent_user
DB_PASSWORD=                          # (REQUIRED) Your database password
DB_PORT=5432

# For Spring (used by docker-compose)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/agent_framework
SPRING_DATASOURCE_USERNAME=agent_user
SPRING_DATASOURCE_PASSWORD=           # (REQUIRED) Same as DB_PASSWORD

# JPA Configuration
JPA_DDL_AUTO=none
JPA_SHOW_SQL=false
HIBERNATE_FORMAT_SQL=true

# =====================================================
# LLM CONFIGURATION (REQUIRED for agent creation)
# =====================================================
LLM_PROVIDER=
LLM_ENABLED=
LLM_API_URL=
LLM_API_KEY=                          # (REQUIRED) Your LLM API key
LLM_MODEL=gpt-4o-mini

# =====================================================
# MCP SERVERS CONFIGURATION
# =====================================================
MCP_DISCOVERY_ENABLED=true

# Jira MCP
MCP_JIRA_URL=                         # e.g., https://your-jira-mcp.ngrok-free.app/mcp-webex-jira/
JIRA_PAT_TOKEN=

# Confluence MCP
MCP_CONFLUENCE_URL=
CONFLUENCE_PAT_TOKEN=

# GitHub MCP
MCP_GITHUB_URL=
GITHUB_PAT_TOKEN=

# Webex MCP
MCP_WEBEX_URL=                        # e.g., https://your-webex-mcp.ngrok-free.app
WEBEX_TOKEN=                          # Your Webex access token

# =====================================================
# PYTHON AGENT BRAIN (REQUIRED for agent execution)
# =====================================================
AGENT_BRAIN_ENABLED=true
AGENT_BRAIN_URL=                      # (REQUIRED) e.g., https://your-agent-brain.ngrok-free.app
DOWNSTREAM_AGENT_URL=                 # (REQUIRED) Same as AGENT_BRAIN_URL

# =====================================================
# LOGGING CONFIGURATION
# =====================================================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_LEVEL_WEBCLIENT=DEBUG

# =====================================================
# SWAGGER / OPENAPI CONFIGURATION
# =====================================================
SWAGGER_API_DOCS_PATH=/v3/api-docs
SWAGGER_UI_PATH=/swagger-ui.html

# =====================================================
# JWT / SECURITY CONFIGURATION (REQUIRED)
# =====================================================
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=                           # (REQUIRED) Minimum 32 characters
JWT_EXPIRATION=86400000               # 24 hours in milliseconds
JWT_REFRESH_EXPIRATION=604800000      # 7 days in milliseconds

# Generate ADMIN_SECRET with: openssl rand -hex 16
ADMIN_SECRET=                         # (REQUIRED) Secret for admin registration

# =====================================================
# ML SERVICE CONFIGURATION (Optional)
# =====================================================
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_ENABLED=false
ML_SERVICE_TIMEOUT=5000

# =====================================================
# TOOL PREDICTION CONFIGURATION
# =====================================================
PREDICTION_METHOD=hybrid              # Options: keyword, llm, cosine, ml_classifier, hybrid
PREDICTION_MIN_CONFIDENCE=0.5
PREDICTION_MAX_TOOLS=5
PREDICTION_CACHE_ENABLED=true
PREDICTION_CACHE_TTL=300              # Cache TTL in seconds

# =====================================================
# THREAD POOL CONFIGURATION
# =====================================================
THREAD_POOL_CORE_SIZE=4
THREAD_POOL_MAX_SIZE=16
THREAD_POOL_QUEUE_CAPACITY=100
